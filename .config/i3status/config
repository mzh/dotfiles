general {
  colors   = true
  interval = 1
}

order += "ipv6"
order += "wireless _first_"
order += "ethernet _first_"
order += "volume master"
order += "battery 0"
order += "battery 1"
order += "tztime local"

ipv6 {
  format_down = ""
}

wireless _first_ {
  format_up   = "W: (%quality at %essid, %frequency) %ip"
  format_down = "W: down"
}

ethernet _first_ {
  format_up   = "E: %ip"
  format_down = "E: down"
}

volume master {
  format       = "Vol: %volume"
  format_muted = "Vol: (%volume)"
  device       = "default"
}

battery 0 {
  format             = "%status %percentage %remaining"
  last_full_capacity = true
  low_threshold      = 15
  threshold_type     = "percentage"
}

battery 1 {
  format             = "%status %percentage %remaining"
  last_full_capacity = true
  low_threshold      = 15
  threshold_type     = "percentage"
}

tztime local {
  format = "%a %b %d %H:%M:%S"
}
